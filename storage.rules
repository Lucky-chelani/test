rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // 1. GLOBAL READ: Allows anyone to see your trek and blog photos
    match /{allPaths=**} {
      allow read: if true;
    }
    
    // 2. BLOG IMAGES (The fix for your current error)
    match /blogImages/{allPaths=**} {
      allow write: if request.auth != null;
    }
    
    // 3. TREK IMAGES
    match /trek-images/{anyPath=**} {
      allow write: if request.auth != null;
    }
    
    match /treks/{wildcard=**} {
      allow write: if request.auth != null;
    }

    // 4. ADMIN & COMMUNITY (Added Ayushman's email for access)
    match /admin/{fileName} {
      allow write: if request.auth != null && 
        (request.auth.token.email in ['luckychelani950@gmail.com', 'ayushman_patel@example.com']);
    }
    
    match /community-images/{fileName} {
      allow write: if request.auth != null && 
        (request.auth.token.email in ['luckychelani950@gmail.com', 'ayushman_patel@example.com'] ||
        (request.resource.metadata != null && request.resource.metadata.adminUpload == 'true'));
    }
    
    // 5. USER AVATARS
    match /avatars/{userId} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}